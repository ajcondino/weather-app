# Hoist ESLint resolver packages to the top-level node_modules.
# eslint-plugin-import v2 resolves plugins by name at runtime using
# Node's require(), which only sees top-level node_modules. Without
# hoisting, pnpm's isolated layout makes them invisible to the plugin.
public-hoist-pattern[]=eslint-import-resolver-*
public-hoist-pattern[]=eslint-plugin-import
