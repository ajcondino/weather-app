{
  "enabledPlugins": {
    "expo@claude-plugins-official": true
  },
  "permissions": {
    "ask": ["Bash(git push:*)", "Bash(git commit:*)", "Bash(pnpm install:*)"],
    "deny": [
      "Read(./.env*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm -rf:*)",
      "WebFetch"
    ]
  }
}
